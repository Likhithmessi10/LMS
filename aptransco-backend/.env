# ─── LMS Backend Settings ─────────────────────────────────────────────
# Primary LMS database (new)
LMS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aptransco-lms

# Existing internship portal database (read-only, for viewing applications)
INTERNSHIP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aptransco

# JWT settings
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Open edX connection
OPENEDX_BASE_URL=http://localhost:18000
OPENEDX_CLIENT_ID=lms-key
OPENEDX_CLIENT_SECRET=lms-secret
OPENEDX_USERNAME=admin
OPENEDX_PASSWORD=admin

# CORS allowed origins (frontend URLs)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# App
APP_NAME=APTRANSCO LMS API
APP_VERSION=1.0.0
DEBUG=true
